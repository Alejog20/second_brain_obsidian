# Copy to .env and fill in. .env is gitignored - never commit real values.

# Required: absolute path on this Mac to your actual Obsidian vault folder
# (the folder containing your .obsidian/ config, not a parent directory).
VAULT_PATH=/Users/you/path/to/your/vault

# Required: config.yaml routes daily_digestion to Gemini's free tier (the rest stays
# on local Ollama). Get a key at https://aistudio.google.com/apikey - never commit it.
GEMINI_API_KEY=

# Not used yet: config.yaml doesn't route anything to these, and llm_router.py has no
# adapter for them. Read by docker-compose.yml and passed into the container regardless,
# so they're a one-line config.yaml change away from working once a provider is added.
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# true (default) = proposals land in _staging/, nothing in the vault changes.
# false = live writes, gated in code by config.yaml's safety.mode also being "apply".
DRY_RUN=true
